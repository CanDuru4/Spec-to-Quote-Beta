# Spec-to-Quote Copilot
# Copy to .env and set values

# OpenAI API (primary: extraction and reasoning use GPT when set)
OPENAI_API_KEY=

# Anthropic API (optional fallback if OPENAI_API_KEY not set)
ANTHROPIC_API_KEY=

# Optional: override data paths
# DEMO_JOBS_PATH=backend/data/demo_jobs.json
# SAMPLE_INQUIRIES_DIR=backend/data/sample_inquiries
